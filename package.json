{
  "name": "h4kken",
  "version": "1.0.0",
  "description": "H4KKEN - 3D Online Fighting Game",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "dev": "concurrently \"bun --watch server.ts\" \"vite\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "bun dist/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "three": "^0.183.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  }
}
