# H4KKEN — Environment Variables
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# The server works without TURN — players will use STUN-only (direct P2P).
# TURN is needed when players are behind symmetric NAT (mobile carriers,
# corporate firewalls). See docs/deployment-guide.md §3 for setup.

# ── Server ─────────────────────────────────────────────────
PORT=3000

# ── TURN Relay (coturn) ────────────────────────────────────
# Generate a secret with: openssl rand -hex 32
TURN_SECRET=
TURN_REALM=
TURN_PORT=3478
TURN_TLS_PORT=5349

# ── TURN Relay (metered.ca OpenRelay — free alternative) ───
# Free 20GB/month TURN relay with geo-routed servers.
# Sign up at: https://www.metered.ca/tools/openrelay/
# Only used when TURN_SECRET is not set (coturn takes priority).
METERED_API_KEY=
METERED_APP=h4kken
